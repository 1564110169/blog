---
import PageHeader from '@/components/PageHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { animeList } from '@/data/anime';
import { PAGES } from '@/lib/site';

const page = PAGES.anime;
---

<BaseLayout title={page.title} description={page.description}>
  <PageHeader eyebrow={page.eyebrow} title={page.headerTitle} description={page.headerDescription} />
  <section class="page-shell grid gap-5 md:grid-cols-2 lg:grid-cols-3">
    {
      animeList.map((anime) => (
        <article class="soft-card p-6">
          <div class="flex items-center justify-between gap-3">
            <span class="tag-chip">{anime.status}</span>
            <span class="rounded-full bg-yume-100 px-3 py-1 text-xs font-black text-yume-500 dark:bg-white/10 dark:text-yume-200">{anime.score}</span>
          </div>
          <h2 class="mt-5 font-display text-2xl font-black text-ink-900 dark:text-white">{anime.title}</h2>
          <p class="mt-2 text-sm font-semibold text-slate-500 dark:text-slate-400">{anime.season}</p>
          <p class="mt-4 leading-7 text-slate-600 dark:text-slate-300">{anime.note}</p>
        </article>
      ))
    }
  </section>
</BaseLayout>
