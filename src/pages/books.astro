---
import PageHeader from '@/components/PageHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { books } from '@/data/books';
import { PAGES } from '@/lib/site';

const page = PAGES.books;
---

<BaseLayout title={page.title} description={page.description}>
  <PageHeader eyebrow={page.eyebrow} title={page.headerTitle} description={page.headerDescription} />
  <section class="page-shell grid gap-5 md:grid-cols-2 lg:grid-cols-3">
    {
      books.map((book) => (
        <article class="soft-card p-6">
          <span class="tag-chip">{book.status}</span>
          <h2 class="mt-5 font-display text-2xl font-black text-ink-900 dark:text-white">{book.title}</h2>
          <p class="mt-2 text-sm font-semibold text-slate-500 dark:text-slate-400">{book.author}</p>
          <p class="mt-4 leading-7 text-slate-600 dark:text-slate-300">{book.note}</p>
        </article>
      ))
    }
  </section>
</BaseLayout>
