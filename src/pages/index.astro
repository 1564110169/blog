---
import { getCollection } from 'astro:content';

import Hero from '@/components/Hero.astro';
import PostCard from '@/components/PostCard.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { link } from '@/lib/paths';
import { sortPosts } from '@/lib/posts';
import { ARTICLE_DEFAULTS, HOME } from '@/lib/site';

const posts = sortPosts(await getCollection('blog'));
const recommendedCategories = ARTICLE_DEFAULTS.recommendedCategories as readonly string[];
const latestPosts = posts.slice(0, ARTICLE_DEFAULTS.latestLimit);
const recommendedPosts = posts
  .filter((post) => recommendedCategories.includes(post.data.category))
  .slice(0, ARTICLE_DEFAULTS.recommendedLimit);
---

<MainLayout title={HOME.title}>
  <Hero />

  <section id={HOME.latest.id} class="home-section">
    <div class="section-head">
      <div>
        <p>{HOME.latest.eyebrow}</p>
        <h2>{HOME.latest.title}</h2>
      </div>
      <a href={link(HOME.latest.href)}>{HOME.latest.linkLabel}</a>
    </div>
    <div class="post-grid">
      {latestPosts.map((post, index) => <PostCard post={post} featured={index === 0} />)}
    </div>
  </section>

  <section class="home-section">
    <div class="section-head">
      <div>
        <p>{HOME.recommended.eyebrow}</p>
        <h2>{HOME.recommended.title}</h2>
      </div>
      <a href={link(HOME.recommended.href)}>{HOME.recommended.linkLabel}</a>
    </div>
    <div class="recommend-grid">
      {recommendedPosts.map((post) => <PostCard post={post} compact />)}
    </div>
  </section>
</MainLayout>
