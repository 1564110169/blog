---
import PageHeader from '@/components/PageHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { projects } from '@/data/projects';
import { PAGES } from '@/lib/site';

const page = PAGES.projects;
---

<BaseLayout title={page.title} description={page.description}>
  <PageHeader eyebrow={page.eyebrow} title={page.headerTitle} description={page.headerDescription} />
  <section class="page-shell grid gap-5 md:grid-cols-2 lg:grid-cols-3">
    {
      projects.map((project) => (
        <a class="soft-card block p-6" href={project.href}>
          <h2 class="font-display text-2xl font-black text-ink-900 dark:text-white">{project.name}</h2>
          <p class="mt-4 leading-7 text-slate-600 dark:text-slate-300">{project.description}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {project.tags.map((tag) => <span class="tag-chip">{tag}</span>)}
          </div>
        </a>
      ))
    }
  </section>
</BaseLayout>
