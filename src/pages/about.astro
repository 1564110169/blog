---
import PageHeader from '@/components/PageHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { asset } from '@/lib/paths';
import { PAGES, PROFILE } from '@/lib/site';

const page = PAGES.about;
---

<BaseLayout title={page.title} description={page.description}>
  <PageHeader eyebrow={page.eyebrow} title={page.title} description={PROFILE.aboutPageDescription} />
  <section class="page-shell grid gap-8 lg:grid-cols-[320px_1fr]">
    <aside class="soft-card p-6 text-center">
      <img class="mx-auto h-32 w-32 rounded-full border-4 border-white object-cover shadow-soft dark:border-white/10" src={asset(PROFILE.avatar)} alt={PROFILE.avatarAlt} />
      <h2 class="mt-5 font-display text-3xl font-black text-ink-900 dark:text-white">{PROFILE.name}</h2>
      <p class="mt-2 text-sm font-semibold text-sakura-500 dark:text-sakura-200">{PROFILE.role}</p>
      <p class="mt-5 text-sm leading-7 text-slate-600 dark:text-slate-300">
        {PROFILE.aboutPageBio}
      </p>
    </aside>
    <div class="soft-card p-6 sm:p-8">
      <div class="prose-yume">
        <h2>{page.content.heading}</h2>
        <p>{page.content.intro}</p>
        <h3>{page.content.writingTitle}</h3>
        <ul>
          {page.content.writingItems.map((item) => <li>{item}</li>)}
        </ul>
        <h3>{page.content.keywordsTitle}</h3>
        <p>{page.content.keywordsText}</p>
      </div>
    </div>
  </section>
</BaseLayout>
