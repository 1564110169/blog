---
import { getCollection } from 'astro:content';

import PageHeader from '@/components/PageHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { link } from '@/lib/paths';
import { getTagCounts, slugify, sortPosts } from '@/lib/posts';
import { PAGES, SITE } from '@/lib/site';

const posts = sortPosts(await getCollection('blog'));
const tagCounts = getTagCounts(posts);
const tags = Object.keys(tagCounts).sort((a, b) => a.localeCompare(b, SITE.locale));
const page = PAGES.tags;
---

<BaseLayout title={page.title} description={page.description}>
  <PageHeader eyebrow={page.eyebrow} title={page.headerTitle} description={page.headerDescription} />
  <section class="page-shell">
    <div class="soft-card flex flex-wrap gap-3 p-6">
      {
        tags.map((tag) => (
          <a class="tag-chip text-sm" href={link(`/tags/${slugify(tag)}`)}>
            #{tag}
            <span class="ml-1 text-slate-400">{tagCounts[tag]}</span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
