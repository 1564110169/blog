---
import BaseHead from '@/components/BaseHead.astro';
import CursorAura from '@/components/CursorAura.astro';
import RightPanel from '@/components/RightPanel.astro';
import SakuraBackdrop from '@/components/SakuraBackdrop.astro';
import Sidebar from '@/components/Sidebar.astro';
import { SITE } from '@/lib/site';
import '@/styles/global.css';
import '@/styles/dashboard.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body class="anime-body antialiased">
    <SakuraBackdrop />
    <CursorAura />
    <Sidebar />
    <div class="site-frame">
      <main class="content-column motion-stage">
        <slot />
      </main>
      <RightPanel />
    </div>
  </body>
</html>
