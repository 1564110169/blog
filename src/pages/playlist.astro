---
import PageHeader from '@/components/PageHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { playlist } from '@/data/playlist';
---

<BaseLayout title="歌单" description="适合写博客时循环播放的歌。">
  <PageHeader eyebrow="Playlist" title="歌单" description="给不同时间段准备一点背景音乐。" />
  <section class="page-shell">
    <div class="soft-card divide-y divide-white/60 overflow-hidden dark:divide-white/10">
      {
        playlist.map((song, index) => (
          <div class="grid gap-3 p-5 sm:grid-cols-[48px_1fr_auto] sm:items-center">
            <span class="font-display text-2xl font-black text-sakura-300">{String(index + 1).padStart(2, '0')}</span>
            <div>
              <h2 class="font-display text-xl font-extrabold text-ink-900 dark:text-white">{song.title}</h2>
              <p class="text-sm text-slate-500 dark:text-slate-400">{song.artist}</p>
            </div>
            <span class="tag-chip w-fit">{song.mood}</span>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
