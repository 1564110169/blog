---
import { link } from '@/lib/paths';
import { FOOTER, SITE } from '@/lib/site';

const year = new Date().getFullYear();
---

<footer class="mt-20 border-t fine-line bg-white/38 py-10 backdrop-blur dark:bg-white/5">
  <div class="page-shell flex flex-col gap-4 text-sm text-slate-600 dark:text-slate-300 sm:flex-row sm:items-center sm:justify-between">
    <p class="font-bold">{FOOTER.copyrightMark} {year} {SITE.author}. {FOOTER.poweredBy}</p>
    <div class="flex flex-wrap gap-3">
      {FOOTER.links.map((item) => <a class="font-bold hover:text-sakura-500" href={link(item.href)}>{item.label}</a>)}
    </div>
  </div>
</footer>
